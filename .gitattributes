# Auto-detect text files, normalize line endings to LF
* text=auto eol=lf

# Binaries — never diff or merge
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.apk binary
*.aab binary
*.keystore binary

# Gradle wrapper — mark as binary to avoid corruption
gradlew.bat text eol=crlf
gradlew text eol=lf

# XML, Kotlin, Gradle — explicit LF
*.xml text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.md text eol=lf
*.pro text eol=lf
*.properties text eol=lf
